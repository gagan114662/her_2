agent:
  max_turns: 60
  reasoning_effort: medium
  verbose: false
  runtime: codex_app_server
  yolo: true
browser:
  inactivity_timeout: 120
code_execution:
  max_tool_calls: 50
  timeout: 300
compression:
  enabled: true
  protect_last_n: 20
  target_ratio: 0.2
  threshold: 0.5
delegation:
  max_iterations: 50
display:
  background_process_notifications: all
  bell_on_complete: false
  busy_input_mode: interrupt
  cleanup_progress: false
  compact: false
  interim_assistant_messages: true
  show_reasoning: false
  skin: default
  streaming: true
  tool_progress: all
group_sessions_per_user: true
hooks_auto_accept: true
mcp_servers:
  aitoearn:
    headers:
      x-api-key: ${AITOEARN_API_KEY}
    url: https://aitoearn.ai/api/unified/mcp
  composio:
    headers:
      x-consumer-api-key: ${COMPOSIO_API_KEY}
    url: https://connect.composio.dev/mcp
  playwright:
    args:
    - '@playwright/mcp'
    - --headless
    command: npx
memory:
  flush_min_turns: 6
  memory_char_limit: 2200
  memory_enabled: true
  nudge_interval: 10
  user_char_limit: 1375
  user_profile_enabled: true
model:
  base_url: http://127.0.0.1:8787
  default: claude-max
  provider: anthropic
prompt_caching:
  cache_ttl: 5m
session_reset:
  at_hour: 4
  idle_minutes: 1440
  mode: both
skills:
  creation_nudge_interval: 15
streaming:
  enabled: false
stt:
  enabled: true
  local:
    model: base
  openai:
    model: whisper-1
terminal:
  backend: local
  container_cpu: 1
  container_disk: 51200
  container_memory: 5120
  container_persistent: true
  cwd: .
  docker_mount_cwd_to_workspace: false
  lifetime_seconds: 300
  timeout: 180
tool_loop_guardrails:
  hard_stop_after:
    exact_failure: 5
    idempotent_no_progress: 5
    same_tool_failure: 8
  hard_stop_enabled: false
  warn_after:
    exact_failure: 2
    idempotent_no_progress: 2
    same_tool_failure: 3
  warnings_enabled: true
